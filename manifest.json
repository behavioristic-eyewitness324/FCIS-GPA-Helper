{
  "manifest_version": 3,
  "name": "FCIS GPA Helper",
  "version": "1.0.4",
  "description": "Automatically calculate and display missing GPA and CGPA for FCIS Ain Shams students.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://ums.asu.edu.eg/StudentGrades",
    "https://raw.githubusercontent.com/AhmedAbdoDev/FCIS-GPA-Helper/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://ums.asu.edu.eg/StudentGrades"],
      "js": [
        "src/constants.js",
        "src/parser.js",
        "src/calculator.js",
        "src/renderer.js",
        "src/updater.js",
        "src/index.js"
      ]
    }
  ]
}
